Options -Indexes
RewriteEngine On

# Serve existing real files/dirs directly
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# API → Symfony backend
RewriteRule ^api/(.+)$ backend/public/index.php [QSA,L]

# Vite static assets (/assets/xxx → frontend/dist/assets/xxx)
RewriteRule ^assets/(.+)$ frontend/dist/assets/$1 [L]

# React SPA — toutes les routes → index.html
RewriteRule ^ frontend/dist/index.html [L]
