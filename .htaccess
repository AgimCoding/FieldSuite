Options -Indexes

RewriteEngine On

# Redirect API requests to Symfony backend
RewriteRule ^api/(.*)$ backend/public/index.php [QSA,L]

# Serve frontend assets directly
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ frontend/dist/$1 [L]

# Fallback: serve React SPA index
RewriteCond %{DOCUMENT_ROOT}/frontend/dist/$1 !-f
RewriteRule ^(.*)$ frontend/dist/index.html [L]
